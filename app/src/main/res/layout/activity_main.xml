<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/fondo_oscuro"
    android:padding="32dp">

    <!-- Logo KREI sobre fondo blanco -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/logo_white_bg"
        android:padding="20dp"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <ImageView
            android:layout_width="200dp"
            android:layout_height="100dp"
            android:src="@drawable/logo_krei"
            android:scaleType="fitCenter"
            android:contentDescription="Logo" />
    </LinearLayout>

    <!-- Card número de línea (se oculta cuando ya está activo) -->
    <LinearLayout
        android:id="@+id/cardNumero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="22dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NÚMERO DE LÍNEA"
            android:textSize="9sp"
            android:textColor="@color/dorado"
            android:letterSpacing="0.18"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etTelefono"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ej: 477-1234567"
            android:textColorHint="@color/gris"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:inputType="phone"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CONFIRMAR"
            android:textColor="@color/blanco"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_dorado"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
