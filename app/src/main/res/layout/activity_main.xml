<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Logo compacto arriba -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/logo_white_bg"
                android:padding="12dp"
                android:gravity="center">
                <ImageView
                    android:layout_width="140dp"
                    android:layout_height="60dp"
                    android:src="@drawable/logo_krei"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card número de línea -->
        <LinearLayout
            android:id="@+id/cardNumero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:layout_marginHorizontal="24dp"
            android:padding="22dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NÚMERO DE LÍNEA"
                android:textSize="9sp"
                android:textColor="@color/dorado"
                android:letterSpacing="0.18"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 477-1234567"
                android:textColorHint="@color/gris"
                android:textColor="@color/blanco"
                android:textSize="18sp"
                android:inputType="phone"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnIniciar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CONFIRMAR"
                android:textColor="@color/blanco"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/btn_dorado"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Título módulos -->
        <TextView
            android:id="@+id/tvModulosTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MÓDULOS"
            android:textColor="@color/gris"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvModulos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0F1629"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/loading_card_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminateTint="@color/rojo_kw" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:background="#C41230"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textColor="@color/blanco"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Por favor espera"
                android:textColor="@color/gris"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
