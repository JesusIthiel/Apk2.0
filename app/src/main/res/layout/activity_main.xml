<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Logo -->
        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="32dp"
            android:text="K"
            android:textSize="36sp"
            android:textColor="@color/fondo_oscuro"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/logo_circle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="KENWORTH DEL ESTE"
            android:textSize="13sp"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="32dp"
            android:text="Rastreo GPS de Flotilla"
            android:textSize="11sp"
            android:textColor="@color/gris" />

        <!-- Card: número de línea -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NÚMERO DE LÍNEA"
                android:textSize="9sp"
                android:textColor="@color/gris"
                android:letterSpacing="0.18"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Ej: 477-1234567"
                android:textColorHint="@color/gris"
                android:textColor="@color/blanco"
                android:textSize="17sp"
                android:inputType="phone"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Card: estado del servicio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ Servicio detenido"
                android:textSize="13sp"
                android:textColor="@color/gris"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ingresa el número de línea y presiona Iniciar"
                android:textSize="11sp"
                android:textColor="@color/gris"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Botón iniciar (solo visible cuando no está activo) -->
        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="INICIAR RASTREO"
            android:textColor="@color/fondo_oscuro"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_dorado"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/tvUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textSize="9sp"
            android:textColor="@color/gris_oscuro" />

    </LinearLayout>
</ScrollView>
