<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══ Contenido principal ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/fondo_oscuro">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:background="#0A0E1F"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menú" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="KENWORTH GPS"
                android:textSize="14sp"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:paddingStart="4dp" />

            <TextView
                android:id="@+id/tvUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/dorado" />
        </LinearLayout>

        <!-- Cuerpo -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Logo K -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="28dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:text="K"
                        android:textSize="36sp"
                        android:textColor="@color/fondo_oscuro"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/logo_circle" />
                </LinearLayout>

                <!-- Card número de línea -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="20dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NÚMERO DE LÍNEA"
                        android:textSize="9sp"
                        android:textColor="@color/dorado"
                        android:letterSpacing="0.18"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Ej: 477-1234567"
                        android:textColorHint="@color/gris"
                        android:textColor="@color/blanco"
                        android:textSize="18sp"
                        android:inputType="phone"
                        android:background="@drawable/input_bg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Card estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○  Servicio detenido"
                        android:textSize="14sp"
                        android:textColor="@color/gris"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ingresa el número de línea y presiona Iniciar"
                        android:textSize="12sp"
                        android:textColor="@color/gris"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>

                <!-- Botón iniciar -->
                <Button
                    android:id="@+id/btnIniciar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="INICIAR RASTREO"
                    android:textColor="@color/fondo_oscuro"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/btn_dorado"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ══ Drawer lateral ══ -->
    <LinearLayout
        android:layout_width="270dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0A0E1F"
        android:orientation="vertical">

        <!-- Header drawer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp"
            android:background="#060911">

            <TextView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:text="K"
                android:textSize="32sp"
                android:textColor="@color/fondo_oscuro"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/logo_circle"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvDrawerNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empleado"
                android:textSize="15sp"
                android:textColor="@color/blanco"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kenworth del Este"
                android:textSize="11sp"
                android:textColor="@color/dorado"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/borde" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Cerrar sesión -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CERRAR SESIÓN"
            android:textColor="@color/blanco"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_rojo"
            android:layout_margin="20dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
