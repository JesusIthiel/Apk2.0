<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_oscuro">

    <!-- Toolbar rojo KREI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dorado"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/blanco"
            android:contentDescription="Regresar" />

        <TextView
            android:id="@+id/tvTituloPdf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvPaginas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/blanco"
            android:textSize="12sp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Pantalla de carga -->
    <LinearLayout
        android:id="@+id/layoutCargando"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/dorado" />

        <TextView
            android:id="@+id/tvCargando"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descargando documento…"
            android:textColor="@color/gris"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Páginas del PDF -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPaginas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:paddingVertical="12dp"
        android:clipToPadding="false" />

</LinearLayout>
