<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/logo_white_bg"
                android:padding="20dp"
                android:gravity="center"
                android:layout_marginTop="56dp"
                android:layout_marginBottom="40dp">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="100dp"
                    android:src="@drawable/logo_krei"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESO"
                    android:textSize="9sp"
                    android:textColor="@color/dorado"
                    android:textStyle="bold"
                    android:letterSpacing="0.18"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USUARIO"
                    android:textSize="9sp"
                    android:textColor="@color/gris"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="tu_usuario"
                    android:textColorHint="@color/gris"
                    android:textColor="@color/blanco"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRASEÑA"
                    android:textSize="9sp"
                    android:textColor="@color/gris"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:textColorHint="@color/gris"
                    android:textColor="@color/blanco"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#ef4444"
                    android:textSize="11sp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="INGRESAR"
                    android:textColor="@color/blanco"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="@drawable/btn_dorado"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0F1629"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/loading_card_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminateTint="@color/rojo_kw" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:background="#C41230"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verificando..."
                android:textColor="@color/blanco"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Por favor espera"
                android:textColor="@color/gris"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
